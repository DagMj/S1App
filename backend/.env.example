APP_NAME=S1 Eksamen API
APP_ENV=dev
APP_DEBUG=true
API_PREFIX=/api/v1
DATABASE_URL=sqlite:///./s1_mvp.db
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Asset storage
# local = lagre filer i backend-containeren (dev)
# s3    = stateless backend med objektlagring (prod)
ASSET_STORAGE_BACKEND=local
ASSETS_DIR=app/assets/generated
ASSETS_LOCAL_URL_PREFIX=/assets

# S3 / Cloudflare R2 (brukes kun når ASSET_STORAGE_BACKEND=s3)
S3_ENDPOINT_URL=
S3_REGION_NAME=auto
S3_BUCKET_NAME=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_KEY_PREFIX=generated
ASSETS_PUBLIC_BASE_URL=

AI_FALLBACK_ENABLED=true

# Admin-bruker som opprettes/oppgraderes automatisk ved oppstart.
# Uten disse variablene opprettes ingen admin (alle brukere er vanlige elever).
# Eksempel for lokal utvikling:
# SEED_ADMIN_EMAIL=admin@skole.no
# SEED_ADMIN_PASSWORD=endre-meg
# SEED_ADMIN_FULL_NAME=Administrator
